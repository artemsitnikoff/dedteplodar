# Virtual envs (heavy, rebuilt in image)
venv/
.venv/

# Built frontend (rebuilt in image stage 1)
admin/frontend/dist/
admin/frontend/node_modules/

# Mounted as volumes at runtime — never bake into image.
# `data/` is a symlink on prod (→ ArkadiyJarvis/data) so we MUST exclude it,
# otherwise COPY brings in a dangling symlink and subsequent mkdir/RUN fails.
data/
base/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Secrets
.env

# Logs
*.log
logs/
