# ── Telegram bot (обязательно) ────────────────────────────────
BOT_TOKEN=
OPERATOR_CHAT_ID=

# ── Claude CLI OAuth (берётся из data/.claude_token.json, shared с ArkadiyJarvis)
# Заполнить один раз при первом деплое — дальше токен автоматически обновляется
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_REFRESH_TOKEN=
# CLAUDE_CLI_PATH=claude
# CLAUDE_MODEL=                 # пусто = дефолт CLI

# ── База знаний (папка base/) ─────────────────────────────────
DATABASE_PATH=base/teplodar.db
PDF_STORAGE_PATH=base/pdfs/

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Ingestion (только при локальном парсинге каталога) ────────
YANDEX_YML_PATH=yandex_yml_base.xml
HTTP_TIMEOUT=30
HTTP_RETRY_ATTEMPTS=3
RATE_LIMIT_DELAY=1.0
MAX_CONCURRENT_REQUESTS=3
USER_AGENT=TeplodarKnowledgeBot/0.1 (+contact@example.com)

# ── RAG (значения по умолчанию подходят) ──────────────────────
# EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
# EMBEDDING_DIM=768
# CHUNK_SIZE_TOKENS=400
# CHUNK_OVERLAP_TOKENS=80
# TOP_K=8
# INDEX_VERSION=e5-base-v1
# DEVICE=cpu
# BATCH_SIZE_EMBEDDING=32
